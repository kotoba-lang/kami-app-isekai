{:paths ["src" "test"]
 :aliases {:test {:extra-paths ["test"]
                  :extra-deps {io.github.cognitect-labs/test-runner
                               {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
                  :main-opts ["-m" "cognitect.test-runner"]}
           ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
           :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
                  :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                              "--fail-level" "error"]}
           ;; スライムハント (Slime Hunt, ADR pending) authoring step: JVM-only, bakes
           ;; public/games/slime-hunt/scene.edn from kami.isekai.chargen/monsters/status
           ;; (character + slime composers, stat→speed derivation) plus this repo's own
           ;; voxel-world/heightmap-color terrain kernel — a dev-only sibling dependency,
           ;; same "zero-dep core, opt-in game/render tooling via alias" shape render-test
           ;; already established (see bb.edn / README's Render-proof section). Needs a
           ;; sibling checkout of kotoba-lang/kami-isekai-assets next to this repo.
           :gen-scene {:extra-paths ["scripts"]
                       :extra-deps {io.github.kotoba-lang/kami-isekai-assets
                                    {:local/root "../kami-isekai-assets"}}
                       :main-opts ["-m" "gen-scene"]}
           ;; The playable game itself: cljs.main (plain `-co`/`-c`, no shadow-cljs/npm —
           ;; same dev-only build shape kami-app-character-creator's `:cljs-app` alias
           ;; uses) compiling dev/slime_hunt/game.cljs, which requires kotoba.engine-clj
           ;; (logic.cljc → WASM, kotoba-lang/kami-engine-clj (standalone SSoT)) and kami.host/input/ui/audio (kotoba-lang/host) +
           ;; scene2d/webgl/fsm (siblings; webgpu is the WebGPU executor) — the exact harness
           ;; gftdcojp/network-isekai's `isekai.game` already runs in production, trimmed to
           ;; this game's own needs. Needs sibling checkouts of kotoba-lang/{webgpu,
           ;; kami-engine-clj} next to this repo.
           :cljs-game {:extra-paths ["dev"]
                       :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}
                                    io.github.kotoba-lang/webgpu
                                    {:local/root "../webgpu"}
                                    io.github.kotoba-lang/host
                                    {:local/root "../host"}
                                    io.github.kotoba-lang/kami-engine-clj
                                    {:local/root "../kami-engine"}}
                       :main-opts ["-m" "cljs.main" "-co" "dev/build.edn" "-c" "slime-hunt.game"]}
           ;; Playtest Co-Scientist (scripts/playtest_coscientist.clj + src/kami_app_isekai/
           ;; playtest/{vision_score,tuning}.cljc): JVM-only, generates+plays+scores+evolves
           ;; スライムハント's tunable "juice" params (see scripts/playtest_coscientist.clj
           ;; docstring). Needs sibling checkouts of kotoba-lang/{langchain,qa-governor} next
           ;; to this repo (same west-manifest sibling-checkout convention as :gen-scene/
           ;; :cljs-game above) — qa-governor's own deps.edn additionally needs a sibling
           ;; checkout of com-junkawasaki/langgraph-clj next to ITS location (see qa-governor's
           ;; deps.edn comment). http-kit/jsonista are the JVM host-fn capabilities
           ;; langchain.jvm's :clj branch needs injected (langchain-clj itself ships zero
           ;; third-party runtime deps by design, ADR-0001 in that repo) — same convention
           ;; mangaka.llm/kotoba-lang/langchain's own :test alias already uses.
           :playtest {:extra-paths ["scripts"]
                      :extra-deps {io.github.kotoba-lang/langchain
                                   {:local/root "../langchain"}
                                   io.github.kotoba-lang/qa-governor
                                   {:local/root "../qa-governor"}
                                   http-kit/http-kit {:mvn/version "2.8.0"}
                                   metosin/jsonista {:mvn/version "0.3.11"}}
                      ;; qa-governor's own langgraph-clj dep transitively drags in a
                      ;; git/sha-pinned kotoba-lang/langchain; force it back to the same
                      ;; local sibling checkout used directly above (qa-governor's own :dev
                      ;; alias demonstrates the identical override for the identical reason).
                      ;; No :main-opts here (deliberately) — `clojure -M:playtest -e …` for
                      ;; interactive/test use and `clojure -M:playtest -m playtest-coscientist
                      ;; …` (scripts/playtest_coscientist.clj) for the CLI both need to work;
                      ;; baking `-m playtest-coscientist` into :main-opts would hijack -e.
                      :override-deps {io.github.kotoba-lang/langchain
                                       {:local/root "../langchain"}}}}}
